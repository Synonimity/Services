# synon_cache env vars — all optional, sensible defaults shown

# "memory" (default, zero infra) or "redis"
CACHE_BACKEND=memory

# Only needed if CACHE_BACKEND=redis
REDIS_URL=

# Default TTL applied when a call site doesn't specify one
CACHE_DEFAULT_TTL_SECONDS=300

# Namespaces every key this module writes — change per-product if
# multiple products might share one Redis instance
CACHE_KEY_PREFIX=synon
