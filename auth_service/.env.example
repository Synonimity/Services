# ---- Database (Supabase Postgres) ----
# Use the "Connection pooling" URI from Supabase project settings, port 6543,
# with sslmode=require. Swap postgresql:// for postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:[email protected]:6543/postgres?ssl=require

# ---- JWT (RS256, asymmetric) ----
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste contents below with literal \n for line breaks, or load from files in config.py
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=kerfsuite-auth
JWT_AUDIENCE=kerfsuite

# ---- App ----
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://app.kerfsuite.com
BASE_URL=https://auth.kerfsuite.com
COOKIE_DOMAIN=.kerfsuite.com
SECRET_KEY=change-me-to-a-long-random-string

# ---- Account lockout ----
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Facebook OAuth ----
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---- Discord OAuth ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Apple Sign In ----
# Apple does not give you a static client secret - it's a short-lived JWT
# you generate yourself, signed with a private key from an Apple Developer
# "Sign in with Apple" key (.p8 file).
APPLE_CLIENT_ID=com.kerfsuite.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./keys/apple_auth_key.p8
