# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql+asyncpg://postgres:[email protected]:6543/postgres?ssl=require

# ---- App ----
ENVIRONMENT=development
BASE_URL=https://notify.kerfsuite.com
ALLOWED_ORIGINS=http://localhost:3000

# Called server-to-server by your app's backend, same pattern as the
# billing service. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_API_KEY=change-me-to-a-long-random-string

# ---- Resend (email provider) ----
# Get this from resend.com/api-keys after verifying a sending domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# From the Webhooks page in your Resend dashboard, after adding an
# endpoint pointing at {BASE_URL}/notifications/webhooks/resend
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App

# ---- Branding (used in the shared email template layout) ----
BRAND_NAME=Your App
BRAND_COLOR=#FF6A00
BRAND_LOGO_URL=
BRAND_FOOTER_TEXT=Your App, Johannesburg, South Africa

# ---- Ops alerts (optional - leave blank to disable a channel) ----
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
