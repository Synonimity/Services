# Rename this file to .env and fill in the keys for whichever providers
# you're actually chaining. You don't need all of these - only the ones
# referenced by the providers you build in your router setup.

ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here

# Optional overrides for OpenAI-compatible endpoints with non-default URLs
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
