# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql+asyncpg://postgres:[email protected]:6543/postgres?ssl=require

# ---- App ----
ENVIRONMENT=development
BASE_URL=https://obs.kerfsuite.com
ALLOWED_ORIGINS=http://localhost:3000

# Every app sending logs/errors here authenticates with this single key.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_API_KEY=change-me-to-a-long-random-string

# How many days to keep raw log entries before they're eligible for
# cleanup. Error issues/occurrences are kept regardless (see README).
LOG_RETENTION_DAYS=30

# ---- Alerting (optional) ----
# Point this at the notifications service built earlier to get a Slack/
# Discord ping the moment a NEW error issue appears, or a previously
# resolved one comes back (a "regression"). Leave NOTIFICATIONS_BASE_URL
# blank to disable - error reporting works fine without it.
NOTIFICATIONS_BASE_URL=https://notify.kerfsuite.com
NOTIFICATIONS_API_KEY=
NOTIFICATIONS_ALERT_CHANNEL=slack
ALERT_ON_NEW_ISSUES=true
ALERT_ON_REGRESSIONS=true
