# Rename this file to .env and fill in your values.
# Only needed if you're using SupabaseBackend - InMemoryBackend needs nothing.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Pricing and plan limits live in pricing.py / plans.py, not here -
# they're structured data (per-model, per-plan), not flat scalars, so
# they're easier to maintain as code than as env vars. Edit those files
# directly to add models or change quota tiers.
