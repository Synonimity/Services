# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql+asyncpg://postgres:[email protected]:6543/postgres?ssl=require

# ---- App ----
ENVIRONMENT=development
BASE_URL=https://billing.kerfsuite.com
ALLOWED_ORIGINS=http://localhost:3000

# This service is meant to be called server-to-server by your app's own
# backend (it builds checkout URLs and manages subscriptions on your
# behalf) - it is NOT meant to be called directly from a browser. Protect
# it with a shared secret your backend sends as the X-API-Key header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_API_KEY=change-me-to-a-long-random-string

# Where the customer's browser lands after paying / cancelling at PayFast.
# These are pages on YOUR app, not on this service.
PAYFAST_RETURN_URL=https://app.kerfsuite.com/billing/success
PAYFAST_CANCEL_URL=https://app.kerfsuite.com/billing/cancelled

# ---- PayFast ----
# sandbox = https://sandbox.payfast.co.za , live = https://www.payfast.co.za
PAYFAST_MODE=sandbox
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# REQUIRED for any recurring/subscription billing - must also be set
# identically on your PayFast account under Settings > Integration.
PAYFAST_PASSPHRASE=
