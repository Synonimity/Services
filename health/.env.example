# synon_health configuration
# All values have working defaults — copy this to .env only if you want
# to override something.

# Shown in /health and /health/deep responses as "service".
HEALTH_SERVICE_NAME=synon-service

# Max seconds any single check is allowed to run before it's marked
# UNHEALTHY as a timeout. Protects /health/deep from hanging on a
# half-dead dependency.
HEALTH_CHECK_TIMEOUT_SECONDS=5.0

# If true, an overall DEGRADED status returns HTTP 503 on /health/deep
# (strict — will pull the instance out of an LB rotation). If false,
# DEGRADED still returns 200 (lenient — instance stays in rotation but
# the body tells you something's slow). UNHEALTHY always returns 503.
HEALTH_DEGRADED_RETURNS_503=false

# Cache the aggregated /health/deep result for this many seconds so an
# aggressive poller (LB, uptime monitor) can't hammer Supabase/Redis on
# every single request. Set to 0 to disable caching.
HEALTH_DEEP_CHECK_CACHE_SECONDS=2.0
