# ---- Database (Supabase Postgres) ----
DATABASE_URL=postgresql+asyncpg://postgres:[email protected]:6543/postgres?ssl=require

# ---- App ----
ENVIRONMENT=development
BASE_URL=http://localhost:8000
# Strongly recommend leaving this as localhost-only origins, or empty,
# since this service has no business being called from a browser at all.
ALLOWED_ORIGINS=

# Comma-separated IP allowlist for an extra layer of defense beyond the
# API keys below. Leave blank to allow any IP (fine for strictly-local
# use; NOT recommended if this is reachable from the internet at all).
# Example: ALLOWED_CLIENT_IPS=41.x.x.x,102.x.x.x
ALLOWED_CLIENT_IPS=

# ---- Master encryption key ----
# Every secret value is encrypted with this before it touches the
# database - Postgres/Supabase never sees plaintext. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store this somewhere that is NOT this repo and NOT the database it
# protects - a password manager entry is the minimum bar. Losing it means
# every stored secret becomes permanently unrecoverable garbage; leaking
# it means every stored secret is compromised. There is no good way
# around this being the one secret you have to protect by hand.
MASTER_ENCRYPTION_KEY=

# ---- Admin key ----
# Full access: create/edit projects, issue and revoke project API keys,
# read/write every project's secrets, read the audit log. Use this only
# from your own machine, never embed it in a deployed app.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_ADMIN_KEY=change-me-to-a-long-random-string
