# synon_ratelimit env vars — all optional, sensible defaults shown

# "memory" (default, zero infra, per-process) or "redis" (shared
# across workers/instances)
RATELIMIT_BACKEND=memory

# Only needed if RATELIMIT_BACKEND=redis
REDIS_URL=

# Default bucket settings applied when a call site doesn't specify
# its own
RATELIMIT_DEFAULT_CAPACITY=10
RATELIMIT_DEFAULT_WINDOW_SECONDS=60

RATELIMIT_KEY_PREFIX=synon_rl
