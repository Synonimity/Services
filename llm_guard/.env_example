# Rename this file to .env and fill in your values.
# Everything here is optional — sane defaults are baked in.

# Injection risk score (0.0-1.0) at which a request is flagged for review
INJECTION_FLAG_THRESHOLD=0.3

# Injection risk score (0.0-1.0) at which a request is blocked outright
INJECTION_BLOCK_THRESHOLD=0.7

# "redact" replaces detected PII with [REDACTED_TYPE] tags.
# "flag_only" leaves text untouched but still reports what was found.
PII_MODE=redact
